# PostgreSQL
POSTGRES_DB=cartrack
POSTGRES_USER=cartrack
POSTGRES_PASSWORD=change_me_strong_password

# MinIO
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_BUCKET=cartrack-prod
# Public URL used in presigned links (set to your media subdomain in prod)
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# JWT
JWT_SECRET=change_me_to_64_char_random_hex_string_for_production_use_only

# Ports (host-side bindings)
API_HOST_PORT=8090
FRONTEND_HOST_PORT=8082
MINIO_CONSOLE_PORT=9001

# CORS
FRONTEND_ORIGIN=http://localhost:8082
